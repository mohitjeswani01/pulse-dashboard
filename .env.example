# Gemini API keys for the /api/summarize serverless function.
# Create keys at https://aistudio.google.com/apikey
# Copy this file to .env.local (gitignored) and fill in real values.
# NEVER commit real keys. These are read server-side only and never shipped to the client.

# Primary key.
GEMINI_API_KEY=

# Fallback key — used automatically if the primary key errors, rate-limits, or times out.
GEMINI_API_KEY_2=
